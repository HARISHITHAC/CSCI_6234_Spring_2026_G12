@startuml
title Sequence Diagram - Manage Availability

actor Host
boundary "Availability UI" as UI
control "AvailabilityController" as AC
entity "Listing" as Listing
entity "AvailabilitySlot" as Slot

Host -> UI : openAvailability(listingId)
UI -> AC : loadCalendar(hostId, listingId)

AC -> Listing : verifyOwnership(hostId, listingId)
Listing --> AC : ownerOk/denied

alt Owner OK
  AC -> Slot : getSlots(listingId)
  Slot --> AC : slots
  AC --> UI : showCalendar(slots)

  Host -> UI : blockDates(start,end)
  UI -> AC : blockDates(listingId,start,end)
  AC -> Slot : createBlockedSlot(listingId,start,end)
  Slot --> AC : slotId
  AC --> UI : calendarUpdated()
  UI --> Host : showUpdatedCalendar()
else Denied
  AC --> UI : showAccessDenied()
  UI --> Host : stop()
end

@enduml