@startuml
title Sequence Diagram - Search & Filter Listings

actor Renter
boundary "Search UI" as UI
control "SearchController" as SC
entity "Listing" as Listing
entity "AvailabilitySlot" as Slot

Renter -> UI : enterCriteria(location,type,dates,budget)
UI -> SC : validateCriteria(criteria)
SC --> UI : criteriaValid

UI -> SC : search(criteria)
SC -> Listing : findByCriteria(criteria)
Listing --> SC : matchingListings

SC -> Slot : getAvailability(matchingListings, dates)
Slot --> SC : availabilityInfo

SC --> UI : showResults(matchingListings, availabilityInfo)
UI --> Renter : displayResults()

@enduml