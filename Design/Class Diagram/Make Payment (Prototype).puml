@startuml
title Sequence Diagram - Make Payment (Prototype)

actor Renter
boundary "Payment UI" as UI
control "PaymentController" as PC
entity "Booking" as Booking
entity "Payment" as Payment

Renter -> UI : openPayment(bookingId)
UI -> PC : loadPaymentScreen(bookingId)

PC -> Booking : load(bookingId)
Booking --> PC : bookingDetails(amount,status=PENDING)

UI --> Renter : showAmount(amount)
Renter -> UI : enterPaymentDetails(method)
UI -> PC : pay(bookingId, method)

PC -> Payment : create(amount, method)
Payment --> PC : paymentId(status=INITIATED)

PC -> Payment : markSuccess(paymentId)
PC -> Booking : setStatus(bookingId, CONFIRMED)

PC --> UI : showReceipt(paymentId)
UI --> Renter : displayConfirmation()

@enduml