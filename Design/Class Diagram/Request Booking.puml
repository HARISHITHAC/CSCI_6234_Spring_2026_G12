@startuml
title Sequence Diagram - Request Booking

actor Renter
boundary "Booking UI" as UI
control "BookingController" as BC
entity "Listing" as Listing
entity "AvailabilitySlot" as Slot
entity "Booking" as Booking

Renter -> UI : chooseListing(listingId)
Renter -> UI : selectDates(startDate,endDate)
UI -> BC : requestBooking(renterId, listingId, dates)

BC -> Listing : load(listingId)
Listing --> BC : listingDetails

BC -> Slot : checkAvailability(listingId, dates)
Slot --> BC : available?/notAvailable

alt Available
  BC -> Booking : create(renterId, listingId, dates)
  Booking --> BC : bookingId(status=PENDING)
  BC --> UI : showBookingSummary(bookingId, totalAmount)
  UI --> Renter : displaySummary()
else Not available
  BC --> UI : showNotAvailable()
  UI --> Renter : chooseOtherDatesOrListing()
end

@enduml